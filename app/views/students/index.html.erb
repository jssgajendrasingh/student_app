
<h1>Student List</h1>

<%= link_to 'New Student', new_student_path, class: 'btn btn-primary' %>

<table border='1'>
  <thead>
    <tr>
      <th>First Name</th>
      <th>Middle Name</th>
      <th>Last Name</th>
      <th>Email</th>
      <th>Phone No</th>
      <th>Address</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @students.each do |student| %>
      <tr>
        <td><%= student.first_name %></td>
        <td><%= student.middle_name %></td>
        <td><%= student.last_name %></td>
        <td><%= student.email %></td>
        <td><%= student.phone_no %></td>
        <td><%= student.address %></td>
        <td>
          <%= link_to 'Show', student_path(student) %> |
          <%= link_to 'Edit', edit_student_path(student) %> |
          <%= link_to 'Delete', student_path(student), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

